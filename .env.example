# Database
DATABASE_URL=postgresql://user:password@localhost:5432/construction_db

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Email Configuration - Option 1: Mailtrap (Development)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
EMAIL_FROM="Construction App <noreply@constructionapp.com>"

# Email Configuration - Option 2: Gmail (Production)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_16_char_app_password
# EMAIL_FROM="Construction App <your_email@gmail.com>"

# SMS Configuration (Optional - for fallback)
# FAST2SMS_API_KEY=your_api_key
# TWO_FACTOR_API_KEY=your_api_key

# Server
PORT=3000
NODE_ENV=development

