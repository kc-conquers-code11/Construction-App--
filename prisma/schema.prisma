  budgetId            String?
  budget              Budget?                   @relation(fields: [budgetId], references: [id])
  budgetCategoryId    String?
  budgetCategory      BudgetCategoryAllocation? @relation(fields: [budgetCategoryId], references: [id])
  purchaseOrderId     String?
  purchaseOrder       PurchaseOrder?            @relation(fields: [purchaseOrderId], references: [id])
  contractorPaymentId String?
  contractorPayment   ContractorPayment?        @relation(fields: [contractorPaymentId], references: [id])
  payrollId           String?
  payroll             Payroll?                  @relation(fields: [payrollId], references: [id])
  cashboxId           String?
  cashbox             ProjectCashbox?           @relation(fields: [cashboxId], references: [id])
  sourceType          TransactionSourceType     @default(DIRECT)
  sourceId            String?
  referenceNo         String?
  requestedById       String
  requestedBy         User                      @relation("TransactionRequestedBy", fields: [requestedById], references: [id])
  approvedById        String?
  approvedBy          User?                     @relation("TransactionApprovedBy", fields: [approvedById], references: [id])
  approvedAt          DateTime?
  rejectedById        String?
  rejectedBy          User?                     @relation("TransactionRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt          DateTime?
  rejectionReason     String?
  voidedById          String?
  voidedBy            User?                     @relation("TransactionVoidedBy", fields: [voidedById], references: [id])
  voidedAt            DateTime?
  voidReason          String?
  notes               String?
  attachmentUrl       String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([projectId, transactionDate(sort: Desc)])
  @@index([companyId, type])
  @@index([status])
  @@index([sourceType, sourceId])
}

model Budget {
  id                   String                     @id @default(uuid())
  budgetNo             String                     @unique
  projectId            String
  project              Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company                    @relation(fields: [companyId], references: [id])
  name                 String
  description          String?
  version              Int                        @default(1)
  status               BudgetStatus               @default(DRAFT)
  budgetPeriod         BudgetPeriodType           @default(PROJECT_PHASE)
  activeForProject     Project?                   @relation("ProjectActiveBudget")
  totalApproved        Float                      @default(0)
  totalCommitted       Float                      @default(0)
  totalSpent           Float                      @default(0)
  totalRemaining       Float                      @default(0)
  utilizationRate      Float                      @default(0)
  startDate            DateTime
  endDate              DateTime?
  fiscalYear           Int?
  contingencyPercent   Float?                     @default(5)
  contingencyAmount    Float?                     @default(0)
  contingencyRemaining Float?                     @default(0)
  requestedById        String
  requestedBy          User                       @relation("BudgetRequester", fields: [requestedById], references: [id])
  requestedAt          DateTime                   @default(now())
  approvedById         String?
  approvedBy           User?                      @relation("BudgetApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime?
  approvalNotes        String?
  rejectionReason      String?
  previousVersionId    String?                    @unique
  previousVersion      Budget?                    @relation("BudgetVersion", fields: [previousVersionId], references: [id])
  nextVersion          Budget?                    @relation("BudgetVersion")
  isActive             Boolean                    @default(true)
  lockedAt             DateTime?
  lockedById           String?
  lockedBy             User?                      @relation("BudgetLocker", fields: [lockedById], references: [id])
  createdById          String
  createdBy            User                       @relation("BudgetCreator", fields: [createdById], references: [id])
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  categories           BudgetCategoryAllocation[]
  revisions            BudgetRevision[]
  transactions         BudgetTransaction[]
  ledgerTransactions   Transaction[]
  alerts               BudgetAlert[]
  documents            BudgetDocument[]
  forecasts            BudgetForecast[]
  purchaseOrders       PurchaseOrder[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([companyId])
  @@index([status])
  @@index([createdById])
}

model BudgetCategoryAllocation {
  id                  String                     @id @default(uuid())
  budgetId            String
  budget              Budget                     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category            BudgetCategory
  subCategory         String?
  description         String?
  allocatedAmount     Float                      @default(0)
  committedAmount     Float                      @default(0)
  spentAmount         Float                      @default(0)
  remainingAmount     Float                      @default(0)
  utilizationRate     Float                      @default(0)
  isContingency       Boolean                    @default(false)
  parentCategoryId    String?
  parentCategory      BudgetCategoryAllocation?  @relation("BudgetSubCategory", fields: [parentCategoryId], references: [id])
  subCategories       BudgetCategoryAllocation[] @relation("BudgetSubCategory")
  warningThreshold    Float?                     @default(80)
  criticalThreshold   Float?                     @default(95)
  monthlyAllocation   Json?
  quarterlyAllocation Json?
  createdById         String
  createdBy           User                       @relation("BudgetCategoryCreator", fields: [createdById], references: [id])
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  alerts              BudgetAlert[]
  purchaseOrderItems  PurchaseOrderItem[]
  transactions        BudgetTransaction[]        @relation("CategoryTransactions")
  ledgerTransactions  Transaction[]
  incomingTransfers   BudgetTransaction[]        @relation("BudgetTransfer")

  @@unique([budgetId, category, subCategory, parentCategoryId])
  @@index([budgetId])
  @@index([category])
}

model BudgetTransaction {
  id                    String                    @id @default(uuid())
  transactionNo         String                    @unique
  budgetId              String
  budget                Budget                    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId            String
  category              BudgetCategoryAllocation  @relation("CategoryTransactions", fields: [categoryId], references: [id])
  transactionType       BudgetTransactionType
  status                BudgetTransactionStatus   @default(PENDING)
  description           String
  amount                Float
  committedAmount       Float?                    @default(0)
  taxAmount             Float?                    @default(0)
  totalAmount           Float
  exchangeRate          Float?                    @default(1)
  currency              String                    @default("INR")
  referenceType         String?
  referenceId           String?
  referenceNo           String?
  materialRequestId     String?
  materialRequest       MaterialRequest?          @relation(fields: [materialRequestId], references: [id])
  expenseId             String?                   @unique
  expense               Expense?                  @relation("ExpenseTransaction", fields: [expenseId], references: [id])
  purchaseOrder         PurchaseOrder?
  contractorPayment     ContractorPayment?
  payrollId             String?
  payroll               Payroll?                  @relation(fields: [payrollId], references: [id])
  equipmentId           String?
  equipment             Equipment?                @relation(fields: [equipmentId], references: [id])
  revisionId            String?
  revision              BudgetRevision?           @relation(fields: [revisionId], references: [id])
  transactionDate       DateTime
  committedDate         DateTime?
  disbursedDate         DateTime?
  transferToCategoryId  String?
  transferToCategory    BudgetCategoryAllocation? @relation("BudgetTransfer", fields: [transferToCategoryId], references: [id])
  notes                 String?
  attachmentUrl         String?
  createdById           String
  createdBy             User                      @relation("BudgetTransactionCreator", fields: [createdById], references: [id])
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  purchaseOrderPayments PurchaseOrderPayment[]

  @@index([budgetId])
  @@index([categoryId])
  @@index([referenceType, referenceId])
  @@index([transactionDate])
  @@index([status])
}

model BudgetRevision {
  id              String              @id @default(uuid())
  revisionNo      String              @unique
  budgetId        String
  budget          Budget              @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  revisionType    BudgetRevisionType
  status          RevisionStatus      @default(DRAFT)
  reason          String
  description     String?
  previousTotal   Float
  newTotal        Float
  changeAmount    Float
  changePercent   Float
  categoryChanges Json
  supportingData  Json?
  requestedById   String
  requestedBy     User                @relation("RevisionRequester", fields: [requestedById], references: [id])
  requestedAt     DateTime            @default(now())
  approvedById    String?
  approvedBy      User?               @relation("RevisionApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  approvalNotes   String?
  rejectionReason String?
  effectiveDate   DateTime
  isApplied       Boolean             @default(false)
  appliedAt       DateTime?
  createdById     String
  createdBy       User                @relation("RevisionCreator", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  transactions    BudgetTransaction[]
  documents       BudgetDocument[]

  @@index([budgetId])
  @@index([revisionType])
}

model BudgetAlert {
  id                String                    @id @default(uuid())
  alertNo           String                    @unique
  budgetId          String
  budget            Budget                    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId        String?
  category          BudgetCategoryAllocation? @relation(fields: [categoryId], references: [id])
  alertType         BudgetAlertType
  severity          String
  title             String
  message           String
  currentAmount     Float
  thresholdAmount   Float
  thresholdPercent  Float
  projectedAmount   Float?
  isResolved        Boolean                   @default(false)
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedBy        User?                     @relation("BudgetAlertResolver", fields: [resolvedById], references: [id])
  resolutionNotes   String?
  resolutionAction  String?
  actionTaken       String?
  revisionCreatedId String?
  notifiedUsers     String[]
  lastNotifiedAt    DateTime?
  notificationCount Int                       @default(0)
  createdById       String
  createdBy         User                      @relation("BudgetAlertCreator", fields: [createdById], references: [id])
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([budgetId])
  @@index([categoryId])
  @@index([alertType])
  @@index([isResolved])
  @@index([severity])
}

model BudgetForecast {
  id                String   @id @default(uuid())
  budgetId          String
  budget            Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  forecastMonth     DateTime
  forecastAmount    Float
  actualAmount      Float?
  variance          Float?
  variancePercent   Float?
  confidenceLevel   Float?   @default(80)
  categoryForecasts Json
  forecastMethod    String?
  forecastFactors   Json?
  previousAccuracy  Float?
  createdById       String
  createdBy         User     @relation("ForecastCreator", fields: [createdById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([budgetId, forecastMonth])
  @@index([budgetId])
  @@index([forecastMonth])
}

model BudgetDocument {
  id           String          @id @default(uuid())
  budgetId     String
  budget       Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  revisionId   String?
  revision     BudgetRevision? @relation(fields: [revisionId], references: [id])
  title        String
  description  String?
  documentType DocumentType
  fileUrl      String
  fileType     String
  fileSize     Int?
  uploadedById String
  uploadedBy   User            @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime        @default(now())

  @@index([budgetId])
  @@index([revisionId])
}

// ============================================
// PURCHASE ORDER MODELS
// ============================================

model PurchaseOrder {
  id                   String                  @id @default(uuid())
  poNumber             String                  @unique
  projectId            String
  project              Project                 @relation(fields: [projectId], references: [id])
  companyId            String
  company              Company                 @relation(fields: [companyId], references: [id])
  title                String
  description          String?
  type                 PurchaseOrderType       @default(MATERIAL)
  status               PurchaseOrderStatus     @default(DRAFT)
  supplierId           String?
  supplier             Supplier?               @relation(fields: [supplierId], references: [id])
  supplierName         String
  supplierAddress      String?
  supplierGST          String?
  supplierPAN          String?
  supplierContact      String?
  supplierEmail        String?
  supplierPhone        String?
  subtotal             Float                   @default(0)
  taxAmount            Float                   @default(0)
  taxRate              Float?                  @default(18)
  discount             Float?                  @default(0)
  discountType         String?
  shippingCost         Float?                  @default(0)
  otherCharges         Float?                  @default(0)
  totalAmount          Float                   @default(0)
  currency             String                  @default("INR")
  paymentTerm          PaymentTerm             @default(NET_30)
  advancePercentage    Float?                  @default(0)
  advanceAmount        Float?                  @default(0)
  advancePaid          Boolean                 @default(false)
  advancePaidDate      DateTime?
  advancePaymentId     String?
  orderDate            DateTime                @default(now())
  expectedDelivery     DateTime?
  actualDelivery       DateTime?
  validUntil           DateTime?
  deliveryAddress      String?
  deliveryInstructions String?
  shippingMethod       String?
  shippingTerms        String?
  requestedById        String
  requestedBy          User                    @relation("PORequester", fields: [requestedById], references: [id])
  requestedAt          DateTime                @default(now())
  approvedById         String?
  approvedBy           User?                   @relation("POApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime?
  approvalNotes        String?
  rejectionReason      String?
  orderedById          String?
  orderedBy            User?                   @relation("POOrderer", fields: [orderedById], references: [id])
  orderedAt            DateTime?
  isOnHold             Boolean                 @default(false)
  holdReason           String?
  holdById             String?
  holdBy               User?                   @relation("POHolder", fields: [holdById], references: [id])
  holdAt               DateTime?
  cancelledById        String?
  cancelledBy          User?                   @relation("POCanceller", fields: [cancelledById], references: [id])
  cancelledAt          DateTime?
  cancellationReason   String?
  budgetId             String?
  budget               Budget?                 @relation(fields: [budgetId], references: [id])
  budgetTransactionId  String?                 @unique
  budgetTransaction    BudgetTransaction?      @relation(fields: [budgetTransactionId], references: [id])
  isClosed             Boolean                 @default(false)
  closedAt             DateTime?
  closedById           String?
  closedBy             User?                   @relation("POCloser", fields: [closedById], references: [id])
  closureNotes         String?
  totalReceived        Float?                  @default(0)
  totalPending         Float?                  @default(0)
  receiptPercent       Float?                  @default(0)
  totalPaid            Float?                  @default(0)
  totalDue             Float?                  @default(0)
  paymentPercent       Float?                  @default(0)
  notes                String?
  internalNotes        String?
  terms                String?
  createdById          String
  createdBy            User                    @relation("POCreator", fields: [createdById], references: [id])
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  items                PurchaseOrderItem[]
  receipts             GoodsReceipt[]
  payments             PurchaseOrderPayment[]
  linkedRequests       MaterialRequest[]
  documents            PurchaseOrderDocument[]
  comments             PurchaseOrderComment[]
  history              PurchaseOrderHistory[]
  expenses             Expense[]
  transactions         Transaction[]

  @@unique([companyId, poNumber])
  @@index([projectId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([budgetId])
}

model PurchaseOrderItem {
  id                 String                    @id @default(uuid())
  purchaseOrderId    String
  purchaseOrder      PurchaseOrder             @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineNo             Int
  description        String
  materialId         String?
  material           Material?                 @relation(fields: [materialId], references: [id])
  specification      String?
  make               String?
  model              String?
  size               String?
  color              String?
  quantity           Float
  unit               String
  unitPrice          Float
  discountPercent    Float?                    @default(0)
  discountAmount     Float?                    @default(0)
  taxPercent         Float?                    @default(18)
  taxAmount          Float?                    @default(0)
  totalPrice         Float
  receivedQuantity   Float                     @default(0)
  pendingQuantity    Float
  acceptedQuantity   Float                     @default(0)
  rejectedQuantity   Float                     @default(0)
  returnedQuantity   Float                     @default(0)
  expectedDelivery   DateTime?
  actualDelivery     DateTime?
  qualityStandard    String?
  inspectionRequired Boolean                   @default(false)
  budgetCategoryId   String?
  budgetCategory     BudgetCategoryAllocation? @relation(fields: [budgetCategoryId], references: [id])
  isClosed           Boolean                   @default(false)
  warrantyPeriod     Int?
  warrantyExpiry     DateTime?
  notes              String?
  receipts           GoodsReceiptItem[]
  materialRequests   MaterialRequest[]

  @@unique([purchaseOrderId, lineNo])
  @@index([purchaseOrderId])
  @@index([materialId])
  @@index([budgetCategoryId])
}

model GoodsReceipt {
  id                 String                  @id @default(uuid())
  grNumber           String                  @unique
  purchaseOrderId    String
  purchaseOrder      PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id])
  projectId          String
  project            Project                 @relation(fields: [projectId], references: [id])
  receiptDate        DateTime                @default(now())
  receivedById       String
  receivedBy         User                    @relation("GoodsReceiver", fields: [receivedById], references: [id])
  deliveryChallanNo  String?
  vehicleNo          String?
  transporter        String?
  receivedAt         String?
  receivedFrom       String?
  inspectedById      String?
  inspectedBy        User?                   @relation("GoodsInspector", fields: [inspectedById], references: [id])
  inspectedAt        DateTime?
  inspectionStatus   InspectionStatus        @default(PENDING)
  inspectionNotes    String?
  qualityCheckPassed Boolean?                @default(false)
  qualityRating      QualityRating?
  qualityNotes       String?
  stockUpdated       Boolean                 @default(false)
  stockUpdatedAt     DateTime?
  isRejected         Boolean                 @default(false)
  rejectionReason    String?
  returnVoucherNo    String?
  returnedDate       DateTime?
  notes              String?
  attachmentUrl      String?
  createdById        String
  createdBy          User                    @relation("GRCreator", fields: [createdById], references: [id])
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  items              GoodsReceiptItem[]
  documents          PurchaseOrderDocument[]

  @@index([purchaseOrderId])
  @@index([projectId])
  @@index([receiptDate])
  @@index([grNumber])
}

model GoodsReceiptItem {
  id                String            @id @default(uuid())
  goodsReceiptId    String
  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItemId          String
  poItem            PurchaseOrderItem @relation(fields: [poItemId], references: [id])
  receivedQuantity  Float
  acceptedQuantity  Float
  rejectedQuantity  Float
  returnedQuantity  Float             @default(0)
  unit              String
  condition         String?
  qualityRating     QualityRating?
  inspectionStatus  InspectionStatus  @default(PENDING)
  inspectionNotes   String?
  inspectedById     String?
  inspectedBy       User?             @relation("ItemInspector", fields: [inspectedById], references: [id])
  inspectedAt       DateTime?
  rejectionReason   String?
  returnVoucherNo   String?
  returnedDate      DateTime?
  stockTransaction  StockTransaction?
  batchNo           String?
  serialNo          String?
  manufacturingDate DateTime?
  expiryDate        DateTime?
  storedLocation    String?
  binLocation       String?
  notes             String?

  @@index([goodsReceiptId])
  @@index([poItemId])
}

model PurchaseOrderPayment {
  id                  String             @id @default(uuid())
  paymentNo           String             @unique
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  amount              Float
  paymentDate         DateTime
  paymentMethod       PaymentMethod
  transactionId       String?            @unique
  referenceNo         String?
  paymentType         String
  paymentOrder        Int?
  status              PaymentStatus      @default(PENDING)
  approvedById        String?
  approvedBy          User?              @relation("POPaymentApprover", fields: [approvedById], references: [id])
  approvedAt          DateTime?
  approvalNotes       String?
  receiptUrl          String?
  budgetTransactionId String?
  budgetTransaction   BudgetTransaction? @relation(fields: [budgetTransactionId], references: [id])
  bankName            String?
  bankAccount         String?
  bankIfsc            String?
  notes               String?
  createdById         String
  createdBy           User               @relation("POPaymentCreator", fields: [createdById], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
  @@index([paymentDate])
}

model Supplier {
  id                  String             @id @default(uuid())
  companyId           String
  company             Company            @relation(fields: [companyId], references: [id])
  supplierCode        String             @unique
  name                String
  type                SupplierType
  subtypes            String[]
  contactPerson       String
  email               String?
  phone               String
  alternatePhone      String?
  whatsapp            String?
  website             String?
  address             String?
  city                String?
  state               String?
  country             String?            @default("India")
  pincode             String?
  gstNumber           String?            @unique
  panNumber           String?            @unique
  tanNumber           String?
  cinNumber           String?
  msmeNumber          String?
  businessType        String?
  yearEstablished     Int?
  bankName            String?
  bankAccount         String?
  bankIfsc            String?
  bankBranch          String?
  upiId               String?
  defaultPaymentTerm  PaymentTerm        @default(NET_30)
  creditLimit         Float?             @default(0)
  creditDays          Int?               @default(30)
  rating              Float?             @default(5.0)
  totalOrders         Int                @default(0)
  totalSpent          Float              @default(0)
  averageDeliveryTime Int?
  onTimeDelivery      Float?             @default(100)
  status              SupplierStatus     @default(ACTIVE)
  verificationStatus  String?
  verifiedAt          DateTime?
  verifiedById        String?
  verifiedBy          User?              @relation("SupplierVerifier", fields: [verifiedById], references: [id])
  blacklistReason     String?
  blacklistedAt       DateTime?
  blacklistedById     String?
  blacklistedBy       User?              @relation("SupplierBlacklister", fields: [blacklistedById], references: [id])
  notes               String?
  tags                String[]
  createdById         String
  createdBy           User               @relation("SupplierCreator", fields: [createdById], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  purchaseOrders      PurchaseOrder[]
  documents           SupplierDocument[]

  @@unique([companyId, supplierCode])
  @@unique([companyId, gstNumber])
  @@unique([companyId, panNumber])
  @@index([companyId])
  @@index([status])
  @@index([rating])
}

model SupplierDocument {
  id           String       @id @default(uuid())
  supplierId   String
  supplier     Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  documentType DocumentType
  fileUrl      String
  fileType     String
  fileSize     Int?
  documentNo   String?
  expiryDate   DateTime?
  isVerified   Boolean      @default(false)
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?        @relation("SupplierDocVerifier", fields: [verifiedById], references: [id])
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([supplierId])
  @@index([documentType])
}

model PurchaseOrderDocument {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
