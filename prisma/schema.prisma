  description     String?
  documentType    PODocumentType
  fileUrl         String
  fileType        String
  fileSize        Int?
  uploadedById    String
  uploadedBy      User           @relation(fields: [uploadedById], references: [id])
  createdAt       DateTime       @default(now())

  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
}

model PurchaseOrderComment {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  content         String
  isInternal      Boolean       @default(false)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([purchaseOrderId])
}

model PurchaseOrderHistory {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  action          POActionType
  fromStatus      String?
  toStatus        String?
  changes         Json?
  oldValue        Json?
  newValue        Json?
  performedById   String
  performedBy     User          @relation(fields: [performedById], references: [id])
  performedAt     DateTime      @default(now())
  ipAddress       String?
  userAgent       String?
  notes           String?

  @@index([purchaseOrderId])
  @@index([performedById])
  @@index([performedAt])
}

model Inventory {
  id                String            @id @default(uuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  location          InventoryLocation @default(GLOBAL)
  projectId         String?
  project           Project?          @relation(fields: [projectId], references: [id])
  materialId        String
  material          Material          @relation(fields: [materialId], references: [id], onDelete: Cascade)
  quantityTotal     Float             @default(0)
  quantityUsed      Float             @default(0)
  quantityAvailable Float             @default(0)
  averageRate       Float             @default(0)
  totalValue        Float             @default(0)
  lastUpdated       DateTime          @default(now()) @updatedAt

  @@unique([companyId, materialId, projectId])
  @@index([projectId])
  @@index([location])
}

model InventoryTransfer {
  id            String                  @id @default(uuid())
  transferNo    String                  @unique
  companyId     String
  company       Company                 @relation(fields: [companyId], references: [id])
  fromLocation  InventoryLocation
  fromProjectId String?
  fromProject   Project?                @relation("TransferSource", fields: [fromProjectId], references: [id])
  toLocation    InventoryLocation
  toProjectId   String?
  toProject     Project?                @relation("TransferDestination", fields: [toProjectId], references: [id])
  transferDate  DateTime                @default(now())
  status        TransferStatus          @default(DRAFT)
  description   String?
  requestedById String
  requestedBy   User                    @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?                   @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  items         InventoryTransferItem[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  user          User?                   @relation(fields: [userId], references: [id])
  userId        String?

  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([status])
}

model InventoryTransferItem {
  id               String            @id @default(uuid())
  transferId       String
  transfer         InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemType         String
  materialId       String?
  material         Material?         @relation(fields: [materialId], references: [id])
  quantity         Float?
  equipmentId      String?
  equipment        Equipment?        @relation(fields: [equipmentId], references: [id])
  assignedRate     Float?
  assignedFuelCost Float?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([transferId])
  @@index([materialId])
  @@index([equipmentId])
}

model ShiftType {
  id           String             @id @default(uuid())
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  multiplier   Float
  description  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdById  String?
  createdBy    User?              @relation("ShiftTypeCreator", fields: [createdById], references: [id])
  attendances  WorkerAttendance[]
  payrollItems PayrollItem[]

  @@unique([companyId, name])
  @@unique([companyId, multiplier])
  @@index([companyId])
  @@index([isActive])
}

model LabourRate {
  id                    String               @id @default(uuid())
  companyId             String
  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workerType            WorkerType
  siteStaffId           String?
  siteStaff             SiteStaff?           @relation(fields: [siteStaffId], references: [id], onDelete: Cascade)
  subcontractorWorkerId String?
  subcontractorWorker   SubcontractorWorker? @relation(fields: [subcontractorWorkerId], references: [id], onDelete: Cascade)
  rate                  Float
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  isCurrent             Boolean              @default(true)
  reason                String?
  approvedById          String?
  approvedBy            User?                @relation("LabourRateApprover", fields: [approvedById], references: [id])
  approvedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdById           String?
  createdBy             User?                @relation("LabourRateCreator", fields: [createdById], references: [id])
  payrollItems          PayrollItem[]

  @@unique([companyId, workerType, siteStaffId, subcontractorWorkerId, effectiveFrom])
  @@index([companyId])
  @@index([workerType])
  @@index([siteStaffId])
  @@index([subcontractorWorkerId])
  @@index([isCurrent])
}

model PayrollItem {
  id                    String               @id @default(uuid())
  payrollId             String
  payroll               Payroll              @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  workerType            WorkerType
  siteStaffId           String?
  siteStaff             SiteStaff?           @relation(fields: [siteStaffId], references: [id], onDelete: SetNull)
  subcontractorWorkerId String?
  subcontractorWorker   SubcontractorWorker? @relation(fields: [subcontractorWorkerId], references: [id], onDelete: SetNull)
  workerName            String
  workerId              String
  designation           String?
  labourRateId          String?
  labourRate            LabourRate?          @relation(fields: [labourRateId], references: [id])
  baseRate              Float
  totalDays             Float
  actualDays            Int
  overtimeDays          Float
  shiftTypeId           String?
  shiftType             ShiftType?           @relation(fields: [shiftTypeId], references: [id])
  shiftMultiplier       Float?               @default(1.0)
  attendanceSummary     Json
  attendanceIds         String[]
  grossAmount           Float
  deductions            Float                @default(0)
  bonus                 Float                @default(0)
  netAmount             Float
  deductionDetails      Json?
  bonusDetails          Json?
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  attendances           WorkerAttendance[]

  @@index([payrollId])
  @@index([workerType])
  @@index([siteStaffId])
  @@index([subcontractorWorkerId])
}
