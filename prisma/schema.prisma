// --- Models ---

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  module      String
  description String?
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([code])
  @@index([module])
}

model Role {
  id            String   @id @default(uuid())
  name          String
  description   String?
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isSystemAdmin Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?

  users              User[]
  rolePermissions    RolePermission[]
  projectAssignments ProjectAssignment[]

  @@unique([companyId, name])
  @@index([companyId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  constraints  Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  grantedById  String?
  grantedBy    User?      @relation("PermissionGranter", fields: [grantedById], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([grantedById])
}

model Company {
  id                 String              @id @default(uuid())
  name               String
  registrationNumber String?             @unique
  gstNumber          String?             @unique
  officeAddress      String?
  officeLatitude     Float?
  officeLongitude    Float?
  officeGeofence     Float               @default(100)
  phone              String?
  email              String?
  website            String?
  logo               String?
  bankName           String?
  bankAccount        String?
  bankIfsc           String?
  bankBranch         String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String?
  createdBy          User?               @relation("CompanyCreator", fields: [createdById], references: [id])
  users              User[]
  roles              Role[]
  clients            Client[]
  projects           Project[]
  materials          Material[]
  equipment          Equipment[]
  settings           CompanySettings?
  payrolls           Payroll[]
  safetyChecks       SafetyCheck[]
  auditLogs          AuditLog[]
  Contractor         Contractor[]
  ContractorProject  ContractorProject[]
  siteStaffs         SiteStaff[]
  budgets            Budget[]
  purchaseOrders     PurchaseOrder[]
  transactions       Transaction[]
  projectCashboxes   ProjectCashbox[]
  suppliers          Supplier[]
  inventories        Inventory[]
  inventoryTransfers InventoryTransfer[]
  shiftTypes         ShiftType[]
  labourRates        LabourRate[]

  @@index([name])
  @@index([createdById])
}

model User {
  id                      String             @id @default(uuid())
  companyId               String?
  company                 Company?           @relation(fields: [companyId], references: [id])
  roleId                  String
  role                    Role               @relation(fields: [roleId], references: [id])
  userType                UserType           @default(EMPLOYEE)
  email                   String?            @unique
  phone                   String             @unique
  password                String
  employeeId              String?
  name                    String
  designation             String?
  department              String?
  employeeStatus          EmployeeStatus     @default(ACTIVE)
  defaultLocation         AttendanceLocation @default(OFFICE)
  salaryType              SalaryType         @default(MONTHLY)
  salary                  Float?
  hourlyRate              Float?
  dateOfBirth             DateTime?
  dateOfJoining           DateTime?
  address                 String?
  emergencyContact        String?
  emergencyPhone          String?
  profilePicture          String?
  aadharNumber            String?
  panNumber               String?
  bankAccount             String?
  ifscCode                String?
  refreshToken            String?
  resetPasswordToken      String?
  resetPasswordExpiry     DateTime?
  lastLogin               DateTime?
  emailVerified           Boolean            @default(false)
  emailVerifiedAt         DateTime?
  phoneVerified           Boolean            @default(false)
  phoneVerifiedAt         DateTime?
  accountSetupCompleted   Boolean            @default(false)
  accountSetupCompletedAt DateTime?
  isActive                Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  createdById             String?
  createdBy               User?              @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers            User[]             @relation("UserCreator")
  

  // Operational Relations
  projectAssignments    ProjectAssignment[]
  createdTasks          Task[]                @relation("TaskCreator")
  assignedTasks         Task[]                @relation("TaskAssignee")
  taskComments          TaskComment[]
  taskAttachments       TaskAttachment[]
  attendances           Attendance[]          @relation("AttendanceUser")
  markedAttendances     Attendance[]          @relation("AttendanceMarker")
  leaves                Leave[]               @relation("LeaveUser")
  approvedLeaves        Leave[]               @relation("LeaveApprover")
  timesheets            Timesheet[]           @relation("TimesheetUser")
  approvedTimesheets    Timesheet[]           @relation("TimesheetApprover")
  preparedDPRs          DailyProgressReport[] @relation("DPRPreparer")
  approvedDPRs          DailyProgressReport[] @relation("DPRApprover")
  preparedWPRs          WeeklyProgressReport[] @relation("WPRPreparer")
  approvedWPRs          WeeklyProgressReport[] @relation("WPRApprover")
  dprPhotos             DPRPhoto[]
  createdExpenses       Expense[]             @relation("ExpenseCreator")
  approvedExpenses      Expense[]             @relation("ExpenseApprover")
  createdInvoices       Invoice[]             @relation("InvoiceCreator")
  approvedInvoices      Invoice[]             @relation("InvoiceApprover")
  createdPayments       Payment[]             @relation("PaymentCreator")
  paymentsReceived      Payment[]             @relation("PaymentReceiver")
  payrolls              Payroll[]
  approvedPayrolls      Payroll[]             @relation("PayrollApprover")
  createdMaterials      Material[]            @relation("MaterialCreator")
  materialRequests      MaterialRequest[]     @relation("MaterialRequester")
  approvedMaterials     MaterialRequest[]     @relation("MaterialApprover")
  orderedMaterials      MaterialRequest[]     @relation("MaterialOrderer")
  stockTransactions     StockTransaction[]
  assignedEquipment     Equipment[]           @relation("EquipmentUser")
  sentMessages          Message[]             @relation("MessageSender")
  receivedMessages      Message[]             @relation("MessageReceiver")
  notifications         Notification[]
  documentsUploaded     Document[]
  conductedSafetyChecks SafetyCheck[]         @relation("SafetyConductor")
  grantedPermissions    RolePermission[]      @relation("PermissionGranter")
  auditLogs             AuditLog[]
  settings              UserSettings?
  createdClients        Client[]              @relation("ClientCreator")
  createdProjects       Project[]             @relation("ProjectCreator")
  createdCompanies      Company[]             @relation("CompanyCreator")
  subtasks              Subtask[]             @relation("SubtaskCreator")
  milestones            Milestone[]           @relation("MilestoneCreator")
  equipment             Equipment[]
  safetyChecks          SafetyCheck[]
  stockAlerts           StockAlert[]
  resolvedSafetyChecks  SafetyCheck[]         @relation("SafetyResolver")
  resolvedStockAlerts   StockAlert[]          @relation("StockAlertResolver")

  // FIX: Added relations for ContractorAssignment
  supervisedAssignments ContractorAssignment[] @relation("AssignmentSupervisor")
  verifiedAssignments   ContractorAssignment[] @relation("AssignmentVerifier")

  // Other Contractor Relations
  createdContractors   Contractor[]         @relation("ContractorCreator")
  createdContProjects  ContractorProject[]  @relation("ContractorProjectCreator")
  createdContPayments  ContractorPayment[]  @relation("ContractorPaymentCreator")
  approvedContPayments ContractorPayment[]  @relation("ContractorPaymentApprover")
  contractorDocs       ContractorDocument[]
  contractorReviews    ContractorReview[]   @relation("ReviewCreator")
  approvedReviews      ContractorReview[]   @relation("ReviewApprover")

  // Timeline relations
  createdTimelines  Timeline[] @relation("TimelineCreatedBy")
  approvedTimelines Timeline[] @relation("TimelineApprovedBy")
  lockedTimelines   Timeline[] @relation("TimelineLockedBy")
  archivedTimelines Timeline[] @relation("TimelineArchivedBy")

  createdTimelineVersions   TimelineVersion[] @relation("TimelineVersionCreatedBy")
  approvedTimelineVersions  TimelineVersion[] @relation("TimelineVersionApprovedBy")
  submittedTimelineVersions TimelineVersion[] @relation("TimelineVersionSubmittedBy")

  timelineActions            TimelineHistory[]
  timelineApprovalsRequested TimelineApproval[] @relation("TimelineApprovalRequestedBy")
  timelineApprovalsToApprove TimelineApproval[] @relation("TimelineApprovalApprover")

  verifiedAttendances         Attendance[]          @relation("AttendanceVerifier")
  siteStaffAssignmentsCreated SiteStaffAssignment[] @relation("SiteStaffAssignmentCreator")
  workerAttendancesVerified   WorkerAttendance[]    @relation("WorkerAttendanceVerifier")
  workerAttendancesMarked     WorkerAttendance[]    @relation("WorkerAttendanceMarker")
  subtaskAssignmentsVerified  SubtaskAssignment[]   @relation("SubtaskAssignmentVerifier")
  subtasksAssigned            SubtaskAssignment[]   @relation("SubtaskAssigner")

  // Budget relations
  budgetRequests          Budget[]                   @relation("BudgetRequester")
  budgetApprovals         Budget[]                   @relation("BudgetApprover")
  budgetLocks             Budget[]                   @relation("BudgetLocker")
  budgetCreations         Budget[]                   @relation("BudgetCreator")
  budgetCategoryCreations BudgetCategoryAllocation[] @relation("BudgetCategoryCreator")
  budgetTransactions      BudgetTransaction[]        @relation("BudgetTransactionCreator")
  budgetRevisions         BudgetRevision[]           @relation("RevisionCreator")
  budgetRevisionRequests  BudgetRevision[]           @relation("RevisionRequester")
  budgetRevisionApprovals BudgetRevision[]           @relation("RevisionApprover")
  budgetAlerts            BudgetAlert[]              @relation("BudgetAlertCreator")
  budgetAlertResolves     BudgetAlert[]              @relation("BudgetAlertResolver")
  budgetForecasts         BudgetForecast[]           @relation("ForecastCreator")

  // Purchase Order relations
  poRequests      PurchaseOrder[] @relation("PORequester")
  poApprovals     PurchaseOrder[] @relation("POApprover")
  poOrders        PurchaseOrder[] @relation("POOrderer")
  poHolds         PurchaseOrder[] @relation("POHolder")
  poCancellations PurchaseOrder[] @relation("POCanceller")
  poClosures      PurchaseOrder[] @relation("POCloser")
  poCreations     PurchaseOrder[] @relation("POCreator")

  // Goods Receipt relations
  goodsReceipts    GoodsReceipt[]     @relation("GoodsReceiver")
  goodsInspections GoodsReceipt[]     @relation("GoodsInspector")
  itemInspections  GoodsReceiptItem[] @relation("ItemInspector")
  grCreations      GoodsReceipt[]     @relation("GRCreator")

  // PO Payment relations
  poPaymentApprovals PurchaseOrderPayment[] @relation("POPaymentApprover")
  poPaymentCreations PurchaseOrderPayment[] @relation("POPaymentCreator")

  // Transaction relations
  projectCashboxCreations ProjectCashbox[] @relation("ProjectCashboxCreator")
  requestedTransactions   Transaction[]    @relation("TransactionRequestedBy")
  approvedTransactions    Transaction[]    @relation("TransactionApprovedBy")
  rejectedTransactions    Transaction[]    @relation("TransactionRejectedBy")
  voidedTransactions      Transaction[]    @relation("TransactionVoidedBy")

  // Supplier relations
  supplierCreations        Supplier[]              @relation("SupplierCreator")
  supplierVerifications    Supplier[]              @relation("SupplierVerifier")
  supplierBlacklists       Supplier[]              @relation("SupplierBlacklister")
  supplierDocVerifications SupplierDocument[]      @relation("SupplierDocVerifier")
  siteStaffs               SiteStaff[]             @relation("SiteStaffCreator")
  budgetDocuments          BudgetDocument[]
  supplierDocuments        SupplierDocument[]
  purchaseOrderDocuments   PurchaseOrderDocument[]
  purchaseOrderComments    PurchaseOrderComment[]
  purchaseOrderHistories   PurchaseOrderHistory[]

  consumedMaterials  MaterialConsumption[]
  operatedEquipment  EquipmentLog[]
  requestedTransfers InventoryTransfer[]   @relation("TransferRequester")
  approvedTransfers  InventoryTransfer[]   @relation("TransferApprover")
  inventoryTransfers InventoryTransfer[]

  // FIXED: Consolidated LabourRate relations
  createdLabourRates  LabourRate[] @relation("LabourRateCreator")
  approvedLabourRates LabourRate[] @relation("LabourRateApprover")

  shiftTypes ShiftType[] @relation("ShiftTypeCreator")

  // Payroll processing
  processedPayrolls Payroll[] @relation("PayrollProcessor")
  paidPayrolls      Payroll[] @relation("PayrollPayer")
  createdPayrolls   Payroll[] @relation("PayrollCreator")

  @@unique([companyId, employeeId])
  @@index([email])
  @@index([phone])
  @@index([companyId])
  @@index([roleId])
  @@index([createdById])
}

model Client {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  companyName   String
  contactPerson String
  email         String?
  phone         String
  gstNumber     String?
  address       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  createdBy     User?     @relation("ClientCreator", fields: [createdById], references: [id])
  projects      Project[]
  invoices      Invoice[]
  payments      Payment[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([createdById])
}

model Project {
  id               String        @id @default(uuid())
  projectId        String
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id])
  name             String
  description      String?
  location         String
  latitude         Float
  longitude        Float
  geofenceRadius   Float         @default(200)
  estimatedBudget  Float
  actualBudget     Float?
  contractValue    Float?
  advanceReceived  Float?        @default(0)
  status           ProjectStatus @default(PLANNING)
  priority         Priority      @default(MEDIUM)
  progress         Int?          @default(0) @db.SmallInt
  startDate        DateTime
  estimatedEndDate DateTime
  actualEndDate    DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdById      String?
  createdBy        User?         @relation("ProjectCreator", fields: [createdById], references: [id])

  projectAssignments ProjectAssignment[]
  milestones         Milestone[]
  tasks              Task[]
  dprs               DailyProgressReport[]
  wprs               WeeklyProgressReport[]
  attendances        Attendance[]
  expenses           Expense[]
  materialRequests   MaterialRequest[]
  invoices           Invoice[]
  documents          Document[]
  messages           Message[]
  projectSettings    ProjectSettings?
  stockTransactions  StockTransaction[]
  timesheets         Timesheet[]
  safetyChecks       SafetyCheck[]
  materials          Material[]            @relation("ProjectMaterials")
  ContractorProject  ContractorProject[]
  ContractorReview   ContractorReview[]
  timelines          Timeline[]

  siteStaffAssignments SiteStaffAssignment[]
  workerAttendances    WorkerAttendance[]
  subtaskAssignments   SubtaskAssignment[]

  // Add budget relations
  budgets           Budget[]
  activeBudgetId    String?  @unique
  activeBudget      Budget?  @relation("ProjectActiveBudget", fields: [activeBudgetId], references: [id])
  totalBudget       Float?   @default(0)
  totalExpenses     Float?   @default(0)
  budgetUtilization Float?   @default(0)

  // Add purchase order relations
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  transactions   Transaction[]
  cashbox        ProjectCashbox?

  inventoryRecords Inventory[]
  consumptions     MaterialConsumption[]
  batches          MaterialBatch[]
  equipmentLogs    EquipmentLog[]
  transfersOut     InventoryTransfer[]   @relation("TransferSource")
  transfersIn      InventoryTransfer[]   @relation("TransferDestination")
  currentEquipment Equipment[]

  @@unique([companyId, projectId])
  @@index([companyId])
  @@index([clientId])
  @@index([createdById])
}

model ProjectAssignment {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?     @relation(fields: [roleId], references: [id])
  designation String?
  startDate   DateTime
  endDate     DateTime?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, projectId, startDate])
  @@index([projectId])
  @@index([userId])
  @@index([roleId])
}

model Attendance {
  id                String             @id @default(uuid())
  userId            String
  user              User               @relation("AttendanceUser", fields: [userId], references: [id])
  locationType      AttendanceLocation
  projectId         String?
  project           Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date              DateTime           @db.Date
  status            AttendanceStatus   @default(PRESENT)
  checkInTime       DateTime?
  checkOutTime      DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkInAccuracy   Float?
  isWithinGeofence  Boolean?
  geofenceType      String?
  distanceFromBase  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  checkInImageUrl   String?
  checkOutImageUrl  String?
  checkInNotes      String?
  checkOutNotes     String?
  deviceInfo        String?
  workingHours      Float?             @default(0)
  overtimeHours     Float?             @default(0)
  totalHours        Float?             @default(0)
  isVerified        Boolean            @default(false)
  verificationNotes String?
  verifiedById      String?
  verifiedBy        User?              @relation("AttendanceVerifier", fields: [verifiedById], references: [id])
  verifiedAt        DateTime?
  markedById        String?
